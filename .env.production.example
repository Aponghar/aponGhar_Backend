# Production Environment Configuration for Render

# Node Environment
NODE_ENV=production
PORT=5000

# Database Configuration (Render MySQL)
# These will be provided by Render when you create the MySQL database
# Format: mysql://username:password@host:port/database
# Get these from Render dashboard after creating the MySQL database
DB_HOST=${MYSQL_HOST}
DB_PORT=${MYSQL_PORT}
DB_NAME=${MYSQL_DATABASE}
DB_USER=${MYSQL_USER}
DB_PASSWORD=${MYSQL_PASSWORD}

# JWT Secret - Generate a strong random secret for production
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=${JWT_SECRET_PRODUCTION}

# Razorpay Configuration (Live Keys)
RAZORPAY_KEY_ID=${RAZORPAY_LIVE_KEY_ID}
RAZORPAY_KEY_SECRET=${RAZORPAY_LIVE_SECRET}

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=${EMAIL_ADDRESS}
EMAIL_PASS=${EMAIL_APP_PASSWORD}
EMAIL_FROM=StayHome <${EMAIL_ADDRESS}>

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=${CLOUDINARY_NAME}
CLOUDINARY_API_KEY=${CLOUDINARY_KEY}
CLOUDINARY_API_SECRET=${CLOUDINARY_SECRET}

# Google OAuth Configuration
GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}

# Allowed Origins (CORS)
ALLOWED_ORIGINS=https://aponghar.in,https://www.aponghar.in,https://api.aponghar.in
